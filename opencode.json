{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "unrealMCP": {
      "type": "local",
      "command": [
        ".venv/Scripts/python.exe",
        "-u",
        "Python/unreal_mcp_server_advanced.py"
      ],
      "cwd": ".",
      "environment": {
        "PYTHONUTF8": "1",
        "PYTHONUNBUFFERED": "1"
      },
      "enabled": true,
      "timeout": 30000
    }
  }
}
